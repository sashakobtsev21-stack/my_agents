# ───────────────────────────────────────────────────────────
#  my_agents — .gitignore
# ───────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
dist-cjs/
build/
out/
output/
coverage/
.nyc_output/
*.tsbuildinfo
*.map

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Environment — block ALL .env variants except .example templates
.env
.env.*
!.env.example
!.env.*.example

# Databases & vector-store / agent state (generated at runtime)
*.db
*.db-journal
*.db-wal
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.rvf
*.rvf.lock

# Claude / Claude-Flow runtime state (keep config dirs, ignore generated state)
.claude/settings.local.json
.claude/checkpoints/
.claude/scheduled_tasks.lock
scheduled_tasks.lock
.claude-flow/
.claude-flow/data/
.claude-flow/logs/
.swarm/
.hive-mind/
.mcp.json
claude-flow.config.json

# Legacy memory/coordination working dirs (regenerated)
/memory/
/coordination/
!/memory/agents/README.md
!/memory/sessions/README.md

# Temp / scratch
tmp/
tmp.json
*.tmp
*.temp
*.bak
*~
*.swp
*.swo
hive-mind-prompt-*.txt

# Codex local config
.codex/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Python (vendored tooling)
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg
*.egg-info/

# Keep first-class config directories tracked
!.claude/
!.claude-plugin/
!v3/@claude-flow/
