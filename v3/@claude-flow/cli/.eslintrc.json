{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "no-restricted-imports": ["error", {
      "paths": [
        {
          "name": "child_process",
          "importNames": ["exec", "execSync"],
          "message": "exec/execSync ALWAYS run a shell — use execFileSync(file, argv) or SafeExecutor from @claude-flow/security instead. See ADR-078."
        }
      ]
    }],
    "no-restricted-modules": ["error", {
      "paths": [
        {
          "name": "child_process",
          "message": "Top-level require('child_process') makes shell-vs-no-shell invisible. Use named imports of execFileSync / execFile / spawn (no shell). See ADR-078."
        }
      ]
    }]
  },
  "overrides": [
    {
      "files": [
        "v3/@claude-flow/security/src/safe-executor.ts",
        "src/commands/daemon.ts",
        "src/mcp-server.ts"
      ],
      "rules": {
        "no-restricted-imports": "off",
        "no-restricted-modules": "off"
      }
    },
    {
      "files": [
        "src/commands/doctor.ts",
        "src/services/container-worker-pool.ts"
      ],
      "rules": {
        "no-restricted-imports": "off",
        "no-restricted-modules": "off"
      }
    }
  ]
}
