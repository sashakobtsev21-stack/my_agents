{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // 57 pre-existing noUnusedLocals errors — opt out at this package
    // until a dedicated cleanup pass lands. cli/hooks/security/
    // embeddings/deployment/codex/browser inherit the strict flag from base.
    "noUnusedLocals": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
